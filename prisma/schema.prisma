generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model budget_allocations {
  budget_id          Int                 @id @default(autoincrement())
  cat_id             Int?
  fiscal_year        Int                 @db.Year
  allocated_amount   Decimal             @default(0.00) @db.Decimal(15, 2)
  used_amount        Decimal?            @default(0.00) @db.Decimal(15, 2)
  department         String?             @db.VarChar(100)
  budget_code        String?             @db.VarChar(50)
  expense_categories expense_categories? @relation(fields: [cat_id], references: [cat_id], onDelete: Restrict, onUpdate: Restrict, map: "budget_allocations_ibfk_1")
  expense_claims     expense_claims[]

  @@index([cat_id], map: "cat_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model drivers {
  driver_id           Int                   @id @default(autoincrement())
  user_id             Int                   @unique(map: "user_id")
  license_number      String?               @db.VarChar(30)
  license_expire      DateTime?             @db.Date
  license_class       String?               @db.VarChar(10)
  is_available        Boolean?              @default(true)
  users               users                 @relation(fields: [user_id], references: [user_id], onUpdate: Restrict, map: "drivers_ibfk_1")
  vehicle_assignments vehicle_assignments[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model expense_approvals {
  ea_id           Int                       @id @default(autoincrement())
  claim_id        Int
  approver_id     Int
  approval_step   Int?                      @db.TinyInt
  action          expense_approvals_action? @default(pending)
  approved_amount Decimal?                  @db.Decimal(12, 2)
  comment         String?                   @db.Text
  action_at       DateTime                  @default(now()) @db.Timestamp(0)
  expense_claims  expense_claims            @relation(fields: [claim_id], references: [claim_id], onUpdate: Restrict, map: "expense_approvals_ibfk_1")
  users           users                     @relation(fields: [approver_id], references: [user_id], onUpdate: Restrict, map: "expense_approvals_ibfk_2")

  @@index([approver_id], map: "approver_id")
  @@index([claim_id], map: "claim_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model expense_categories {
  cat_id             Int                             @id @default(autoincrement())
  cat_name           String                          @db.VarChar(100)
  cat_code           String?                         @db.VarChar(20)
  budget_type        expense_categories_budget_type?
  max_per_claim      Decimal?                        @db.Decimal(12, 2)
  budget_allocations budget_allocations[]
  expense_claims     expense_claims[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model expense_claims {
  claim_id           Int                    @id @default(autoincrement())
  claim_number       String?                @unique(map: "claim_number") @db.VarChar(30)
  claimant_id        Int
  cat_id             Int?
  budget_id          Int?
  travel_request_id  Int?
  claim_date         DateTime               @db.Date
  total_amount       Decimal                @default(0.00) @db.Decimal(12, 2)
  description        String?                @db.Text
  status             expense_claims_status? @default(draft)
  paid_at            DateTime?              @db.DateTime(0)
  created_at         DateTime               @default(now()) @db.Timestamp(0)
  expense_approvals  expense_approvals[]
  users              users                  @relation(fields: [claimant_id], references: [user_id], onUpdate: Restrict, map: "expense_claims_ibfk_1")
  expense_categories expense_categories?    @relation(fields: [cat_id], references: [cat_id], onDelete: Restrict, onUpdate: Restrict, map: "expense_claims_ibfk_2")
  budget_allocations budget_allocations?    @relation(fields: [budget_id], references: [budget_id], onDelete: Restrict, onUpdate: Restrict, map: "expense_claims_ibfk_3")
  travel_requests    travel_requests?       @relation(fields: [travel_request_id], references: [request_id], onDelete: Restrict, onUpdate: Restrict, map: "expense_claims_ibfk_4")
  expense_items      expense_items[]

  @@index([budget_id], map: "budget_id")
  @@index([cat_id], map: "cat_id")
  @@index([claimant_id], map: "claimant_id")
  @@index([travel_request_id], map: "travel_request_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model expense_items {
  item_id        Int            @id @default(autoincrement())
  claim_id       Int
  item_name      String         @db.VarChar(300)
  item_date      DateTime?      @db.Date
  amount         Decimal        @default(0.00) @db.Decimal(10, 2)
  unit           String?        @db.VarChar(30)
  quantity       Decimal?       @default(1.00) @db.Decimal(8, 2)
  receipt_number String?        @db.VarChar(50)
  receipt_file   String?        @db.VarChar(300)
  expense_claims expense_claims @relation(fields: [claim_id], references: [claim_id], onUpdate: Restrict, map: "expense_items_ibfk_1")

  @@index([claim_id], map: "idx_ei_claim")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model news_categories {
  category_id        Int                  @id @default(autoincrement())
  category_name      String               @unique(map: "category_name") @db.VarChar(100)
  category_code      String?              @db.VarChar(20)
  is_active          Boolean?             @default(true)
  news_daily_summary news_daily_summary[]
  news_items         news_items[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model news_daily_summary {
  summary_id      Int              @id @default(autoincrement())
  summary_date    DateTime         @db.Date
  category_id     Int?
  total_news      Int              @default(0)
  positive_count  Int?             @default(0)
  negative_count  Int?             @default(0)
  neutral_count   Int?             @default(0)
  note            String?          @db.Text
  news_categories news_categories? @relation(fields: [category_id], references: [category_id], onDelete: Restrict, onUpdate: Restrict, map: "news_daily_summary_ibfk_1")

  @@index([category_id], map: "category_id")
  @@index([summary_date], map: "idx_summary_date")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model news_items {
  news_id         BigInt                @id @default(autoincrement())
  category_id     Int?
  source_id       Int?
  news_title      String                @db.VarChar(500)
  news_summary    String?               @db.Text
  news_url        String?               @db.VarChar(500)
  news_date       DateTime              @db.Date
  sentiment       news_items_sentiment? @default(neutral)
  is_highlighted  Boolean?              @default(false)
  created_at      DateTime              @default(now()) @db.Timestamp(0)
  created_by      Int?
  news_categories news_categories?      @relation(fields: [category_id], references: [category_id], onDelete: Restrict, onUpdate: Restrict, map: "news_items_ibfk_1")
  news_sources    news_sources?         @relation(fields: [source_id], references: [source_id], onDelete: Restrict, onUpdate: Restrict, map: "news_items_ibfk_2")

  @@index([category_id], map: "idx_news_cat")
  @@index([news_date], map: "idx_news_date")
  @@index([source_id], map: "source_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model news_sources {
  source_id   Int                       @id @default(autoincrement())
  source_name String                    @db.VarChar(150)
  source_type news_sources_source_type? @default(online)
  source_url  String?                   @db.VarChar(255)
  news_items  news_items[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model travel_approvals {
  approval_id     Int                      @id @default(autoincrement())
  request_id      Int
  approver_id     Int
  approval_step   Int                      @db.TinyInt
  action          travel_approvals_action? @default(pending)
  comment         String?                  @db.Text
  action_at       DateTime                 @default(now()) @db.Timestamp(0)
  travel_requests travel_requests          @relation(fields: [request_id], references: [request_id], onUpdate: Restrict, map: "travel_approvals_ibfk_1")
  users           users                    @relation(fields: [approver_id], references: [user_id], onUpdate: Restrict, map: "travel_approvals_ibfk_2")

  @@index([approver_id], map: "approver_id")
  @@index([request_id], map: "request_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model travel_participants {
  participant_id  Int                       @id @default(autoincrement())
  request_id      Int
  user_id         Int
  role            travel_participants_role? @default(member)
  remark          String?                   @db.VarChar(200)
  travel_requests travel_requests           @relation(fields: [request_id], references: [request_id], onUpdate: Restrict, map: "travel_participants_ibfk_1")
  users           users                     @relation(fields: [user_id], references: [user_id], onUpdate: Restrict, map: "travel_participants_ibfk_2")

  @@index([request_id], map: "idx_tp_request")
  @@index([user_id], map: "user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model travel_requests {
  request_id          Int                             @id @default(autoincrement())
  doc_number          String?                         @unique(map: "doc_number") @db.VarChar(30)
  requester_id        Int
  purpose             String                          @db.Text
  destination         String                          @db.VarChar(300)
  depart_date         DateTime                        @db.Date
  return_date         DateTime                        @db.Date
  travel_days         Int?                            @default(0)
  transport_type      travel_requests_transport_type?
  status              travel_requests_status?         @default(draft)
  budget_code         String?                         @db.VarChar(50)
  created_at          DateTime                        @default(now()) @db.Timestamp(0)
  expense_claims      expense_claims[]
  travel_approvals    travel_approvals[]
  travel_participants travel_participants[]
  vehicle_requests    vehicle_requests[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  user_id             Int                   @id @default(autoincrement())
  employee_code       String?               @unique(map: "employee_code") @db.VarChar(20)
  full_name           String                @db.VarChar(200)
  position            String?               @db.VarChar(150)
  department          String?               @db.VarChar(100)
  level               String?               @db.VarChar(50)
  email               String?               @unique(map: "email") @db.VarChar(150)
  phone               String?               @db.VarChar(20)
  is_active           Boolean?              @default(true)
  drivers             drivers?
  expense_approvals   expense_approvals[]
  expense_claims      expense_claims[]
  travel_approvals    travel_approvals[]
  travel_participants travel_participants[]
  vehicle_requests    vehicle_requests[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model vehicle_assignments {
  assign_id        Int              @id @default(autoincrement())
  vreq_id          Int
  vehicle_id       Int
  driver_id        Int
  assign_by        Int?
  odometer_start   Int?
  odometer_end     Int?
  fuel_used        Decimal?         @db.Decimal(8, 2)
  note             String?          @db.Text
  assigned_at      DateTime         @default(now()) @db.Timestamp(0)
  vehicle_requests vehicle_requests @relation(fields: [vreq_id], references: [vreq_id], onUpdate: Restrict, map: "vehicle_assignments_ibfk_1")
  vehicles         vehicles         @relation(fields: [vehicle_id], references: [vehicle_id], onUpdate: Restrict, map: "vehicle_assignments_ibfk_2")
  drivers          drivers          @relation(fields: [driver_id], references: [driver_id], onUpdate: Restrict, map: "vehicle_assignments_ibfk_3")

  @@index([driver_id], map: "driver_id")
  @@index([vehicle_id], map: "vehicle_id")
  @@index([vreq_id], map: "vreq_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model vehicle_requests {
  vreq_id             Int                      @id @default(autoincrement())
  doc_number          String?                  @unique(map: "doc_number") @db.VarChar(30)
  requester_id        Int
  travel_request_id   Int?
  purpose             String                   @db.Text
  destination         String                   @db.VarChar(300)
  start_datetime      DateTime                 @db.DateTime(0)
  end_datetime        DateTime                 @db.DateTime(0)
  passenger_count     Int?                     @default(1) @db.TinyInt
  status              vehicle_requests_status? @default(pending)
  created_at          DateTime                 @default(now()) @db.Timestamp(0)
  vehicle_assignments vehicle_assignments[]
  users               users                    @relation(fields: [requester_id], references: [user_id], onUpdate: Restrict, map: "vehicle_requests_ibfk_1")
  travel_requests     travel_requests?         @relation(fields: [travel_request_id], references: [request_id], onDelete: Restrict, onUpdate: Restrict, map: "vehicle_requests_ibfk_2")

  @@index([requester_id], map: "requester_id")
  @@index([travel_request_id], map: "travel_request_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model vehicles {
  vehicle_id          Int                    @id @default(autoincrement())
  plate_number        String                 @unique(map: "plate_number") @db.VarChar(20)
  brand               String                 @db.VarChar(80)
  model               String?                @db.VarChar(80)
  year                Int?                   @db.Year
  vehicle_type        vehicles_vehicle_type?
  seat_count          Int?                   @db.TinyInt
  status              vehicles_status?       @default(available)
  fuel_type           vehicles_fuel_type?
  department          String?                @db.VarChar(100)
  vehicle_assignments vehicle_assignments[]
}

enum news_sources_source_type {
  online
  print
  tv
  radio
}

enum expense_categories_budget_type {
  recurrent
  capital
}

enum travel_participants_role {
  leader
  member
  driver
}

enum expense_approvals_action {
  approved
  rejected
  pending
}

enum travel_approvals_action {
  approved
  rejected
  pending
}

enum vehicles_vehicle_type {
  sedan
  pickup
  van
  bus
  suv
}

enum news_items_sentiment {
  positive
  negative
  neutral
}

enum vehicles_status {
  available
  in_use
  maintenance
}

enum travel_requests_transport_type {
  gov_car
  plane
  train
  bus
  private
}

enum vehicles_fuel_type {
  gasoline
  diesel
  electric
  hybrid
}

enum expense_claims_status {
  draft
  submitted
  approved
  paid
  rejected
}

enum travel_requests_status {
  draft
  pending
  approved
  rejected
}

enum vehicle_requests_status {
  pending
  approved
  assigned
  completed
  cancelled
}
